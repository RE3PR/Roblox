-- Draggable
local dragging = false
local dragStart, startPos
frame.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		dragging = true
		dragStart = input.Position
		startPos = frame.Position
	end
end)
frame.InputEnded:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)
game:GetService("UserInputService").InputChanged:Connect(function(input)
	if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
		local delta = input.Position - dragStart
		frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
	end
end)

-- Main claim function - only 1 per click
local function claimOne()
	status.Text = "Claiming..."
	
	-- Force the values the server checks
	local smileysPromo = player:WaitForChild("SmileysPromo", 3)
	if smileysPromo then
		local freeMax = smileysPromo:FindFirstChild("FreeMax")
		if freeMax then
			freeMax.Value = 10   -- Give buffer
		end
		
		local viewed = smileysPromo:FindFirstChild("Viewed")
		if viewed then viewed.Value = 1 end
	end
	
	-- Fire the remote
	claimRemote:FireServer()
	
	status.Text = "✅ +1 Max Size Sent!"
	task.wait(1.2)
	status.Text = "Ready - Click again"
end

claimBtn.MouseButton1Click:Connect(claimOne)

