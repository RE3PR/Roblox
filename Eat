-- ==================== AUTO REBIRTH ====================
local function tryRebirth()
    -- Common rebirth methods - adjust based on your game
    if player:FindFirstChild("Rebirth") or player.leaderstats:FindFirstChild("Rebirths") then
        local args = {}
        -- Try common RemoteEvents/Functions
        local rebirthRemote = game.ReplicatedStorage:FindFirstChild("RebirthEvent", true) 
                         or game.ReplicatedStorage:FindFirstChild("Rebirth", true)
        
        if rebirthRemote then
            if rebirthRemote:IsA("RemoteEvent") then
                rebirthRemote:FireServer()
            elseif rebirthRemote:IsA("RemoteFunction") then
                rebirthRemote:InvokeServer()
            end
        end
    end
end

-- ==================== AUTO EAT ====================
local function getNearestFood()
    local nearest = nil
    local shortestDistance = math.huge
    
    for _, food in ipairs(foodFolder:GetChildren()) do
        if food:IsA("Model") then
            local pickupPart = food:FindFirstChild("AutoGeneratedPickupPart") or food:FindFirstChildWhichIsA("Part")
            if pickupPart then
                local distance = (pickupPart.Position - root.Position).Magnitude
                if distance < shortestDistance and distance < 300 then
                    shortestDistance = distance
                    nearest = pickupPart
                end
            end
        end
    end
    return nearest
end

local function walkToFood()
    if not AUTO_EAT_ENABLED then return end
    
    local target = getNearestFood()
    if target then
        -- Move towards food
        local direction = (target.Position - root.Position).Unit
        root.CFrame = root.CFrame + direction * 8 -- Adjust speed
        
        -- Optional: Fire proximity prompt if exists
        local prompt = target:FindFirstChildWhichIsA("ProximityPrompt")
        if prompt then
            prompt:InputHoldBegin()
            wait(0.2)
            prompt:InputHoldEnd()
        end
    end
end

-- Main Loops
RunService.Heartbeat:Connect(function()
    if AUTO_REBIRTH_ENABLED then
        tryRebirth()
    end
end)

spawn(function()
    while wait(EAT_INTERVAL) do
        if AUTO_EAT_ENABLED then
            walkToFood()
        end
