-- Fast dump function with batching
local results = {}
local batchCount = 0
local paused = false
local estimatedTotal = 40000

local function processBatch()
    if paused then
        task.wait(0.05)
        return false
    end
    
    batchCount = batchCount + 1
    local percent = math.floor((totalInstances / estimatedTotal) * 100)
    speedLabel.Text = string.format("Progress: %d/%d (%d%%)", batchCount, batchSize, percent)
    
    if batchCount >= batchSize then
        paused = true
        statusLabel.Text = string.format("Pausing %ds (processed %d instances)...", batchDelay, batchCount)
        
        for i = batchDelay, 1, -1 do
            if not isRunning then break end
            speedLabel.Text = string.format("Resuming in %d seconds... (%d%%)", i, percent)
            task.wait(1)
        end
        
        batchCount = 0
        paused = false
        statusLabel.Text = "Scanning game..."
        speedLabel.Text = string.format("Progress: 0/%d (%d%%)", batchSize, percent)
        
        -- Force garbage collection to prevent memory issues
        collectgarbage()
    end
    
    return true
end

local function dump(inst, depth)
    if not isRunning then return end
    
    if not processBatch() then
        return dump(inst, depth)
    end
    
    local indent = string.rep("  ", depth)
    local name = inst.Name ~= "" and inst.Name or "Unnamed"
    table.insert(results, indent .. name .. " (" .. inst.ClassName .. ")")
    totalInstances = totalInstances + 1
    
    -- Update UI every 500 instances (less frequent = faster)
    if totalInstances % 500 == 0 then
        local percent = math.floor((totalInstances / estimatedTotal) * 100)
        countLabel.Text = string.format("Instances: %d / %d (%d%%)", totalInstances, estimatedTotal, percent)
        statusLabel.Text = string.format("Scanning: %s", inst.ClassName)
        task.wait()
    end
    
    local children = inst:GetChildren()
    for i = 1, #children do
        dump(children[i], depth + 1)
        if not isRunning then break end
    end
end

