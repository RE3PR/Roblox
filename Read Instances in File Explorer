-- Fast dump function with batching
local batchCount = 0
local paused = false

local function processBatch()
    if paused then
        task.wait(0.05)
        return false
    end
    
    batchCount = batchCount + 1
    speedLabel.Text = string.format("Batch progress: %d/%d", batchCount, batchSize)
    
    if batchCount >= batchSize then
        paused = true
        statusLabel.Text = string.format("Pausing %ds (processed %d instances)...", batchDelay, batchCount)
        
        -- Show countdown
        for i = batchDelay, 1, -1 do
            if not isRunning then break end
            speedLabel.Text = string.format("Resuming in %d seconds...", i)
            task.wait(1)
        end
        
        batchCount = 0
        paused = false
        statusLabel.Text = "Scanning game..."
        speedLabel.Text = string.format("Batch progress: 0/%d", batchSize)
    end
    
    return true
end

local function dump(inst, depth)
    if not isRunning then return end
    
    if not processBatch() then
        return dump(inst, depth)
    end
    
    local indent = string.rep("  ", depth)
    local name = inst.Name ~= "" and inst.Name or "Unnamed"
    local instanceLine = indent .. name .. " (" .. inst.ClassName .. ")"
    
    table.insert(allInstances, instanceLine)
    totalInstances = totalInstances + 1
    
    -- Update UI more efficiently (every 250 instances)
    if totalInstances % 250 == 0 then
        countLabel.Text = string.format("Instances dumped: %d", totalInstances)
        statusLabel.Text = string.format("Scanning: %s", inst.ClassName)
        task.wait()
    end
    
    -- Faster child iteration
    local children = inst:GetChildren()
    for i = 1, #children do
        dump(children[i], depth + 1)
        if not isRunning then break end
    end
end

