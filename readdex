-- Make the UI draggable
local dragging = false
local dragInput
local dragStart
local startPos

local function updateDrag(input)
    local delta = input.Position - dragStart
    mainFrame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
end

title.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = mainFrame.Position
    end
end)

title.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

game:GetService("UserInputService").InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        updateDrag(input)
    end
end)

-- Start scanning (DFS iterative for proper tree order + live updates)
local startTime = os.clock()
local instanceCount = 0
local dumpLines = {}

-- Prepare stack for DFS (depth-first so children stay grouped under parents)
local stack = {}

for _, serviceName in ipairs(ServicesToDump) do
    local success, service = pcall(function()
        return game:GetService(serviceName)
    end)
    if success and service then
        table.insert(stack, {instance = service, indent = ""})
    end
end

statusLabel.Text = "Scanning game hierarchy..."

while #stack > 0 do
    local current = table.remove(stack)  -- LIFO = DFS
    local inst = current.instance
    local indent = current.indent

    -- Build tree line
    local line = indent .. "[" .. inst.ClassName .. "] " .. inst.Name
    table.insert(dumpLines, line)

    instanceCount = instanceCount + 1

    -- Live UI update every 150 instances (smooth + no lag)
    if instanceCount % 150 == 0 then
        local elapsed = os.clock() - startTime
        timeLabel.Text = "Time elapsed: " .. math.floor(elapsed) .. " seconds"
        countLabel.Text = "Instances scanned: " .. instanceCount
        progressBar.Size = UDim2.new(math.clamp(instanceCount / 5000, 0, 1), 0, 1, 0)  -- rough progress
        task.wait()  -- yield so UI actually renders
    end

    -- Add children to stack (in reverse so original order is preserved)
    local children = inst:GetChildren()
    for i = #children, 1, -1 do
        table.insert(stack, {
            instance = children[i],
            indent = indent .. "  "
        })
    end
end

-- Final UI update
local totalTime = os.clock() - startTime
timeLabel.Text = "Time elapsed: " .. string.format("%.2f", totalTime) .. " seconds"
countLabel.Text = "Instances scanned: " .. instanceCount
statusLabel.Text = "Scan complete! Writing file..."
progressBar.Size = UDim2.new(1, 0, 1, 0)

-- Ensure folder exists
pcall(function()
    if not isfolder(folderPath) then
        makefolder(folderPath)
    end
end)

-- Write the full dump
local fullDump = table.concat(dumpLines, "\n") .. "\n\n-- Dump finished in " .. string.format("%.2f", totalTime) .. " seconds. Total instances: " .. instanceCount

local writeSuccess, writeErr = pcall(function()
    writefile(filePath, fullDump)
end)

if writeSuccess then
    statusLabel.Text = "✅ SUCCESS! File saved to:"
    local pathLabel = Instance.new("TextLabel")
    pathLabel.Size = UDim2.new(1, -20, 0, 60)
    pathLabel.Position = UDim2.new(0, 10, 0, 190)
    pathLabel.BackgroundTransparency = 1
    pathLabel.Text = filePath
    pathLabel.TextColor3 = Color3.fromRGB(0, 255, 100)
    pathLabel.TextScaled = true
    pathLabel.TextWrapped = true
    pathLabel.Font = Enum.Font.Code
    pathLabel.Parent = mainFrame
else
    statusLabel.Text = "❌ Failed to write file"
    local errLabel = Instance.new("TextLabel")
    errLabel.Size = UDim2.new(1, -20, 0, 80)
    errLabel.Position = UDim2.new(0, 10, 0, 190)
    errLabel.BackgroundTransparency = 1
    errLabel.Text = "Error: " .. tostring(writeErr) .. "\n\nMake sure the folder exists and your executor allows full path writing."
    errLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    errLabel.TextScaled = true
    errLabel.TextWrapped = true
    errLabel.Font = Enum.Font.Gotham
    errLabel.Parent = mainFrame
end

print("Game dump completed! " .. instanceCount .. " instances saved to " .. filePath)
