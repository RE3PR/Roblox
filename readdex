-- Roblox Game Dumper (Executor Script)
-- Scans the specified services + all descendants
-- Live UI with timer + instance counter
-- Dumps full hierarchy tree to the exact path you requested
-- Works in any executor that supports writefile/makefolder (Fluxus, Solara, Wave, etc.)

local ServicesToDump = {
    "Workspace",
    "ReplicatedStorage",
    "Players",
    "Lighting",
    "StarterGui",
    "StarterPack",
    "StarterPlayer",
    "Teams",
    "SoundService",
    "ReplicatedFirst",
    "ServerScriptService",
    "ServerStorage",
    "Chat",
    "TextChatService"
}

local filePath = "C:\\Users\\RYZEN7 GAMER\\New Folder\\game_dump.txt"
local folderPath = "C:\\Users\\RYZEN7 GAMER\\New Folder"

