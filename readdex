-- Format time function
local function formatTime(seconds)
    local mins = math.floor(seconds / 60)
    local secs = math.floor(seconds % 60)
    return string.format("%d:%02d", mins, secs)
end

-- Timer update
coroutine.wrap(function()
    while isRunning and screenGui and screenGui.Parent do
        local elapsed = tick() - startTime
        timerLabel.Text = "Time: " .. formatTime(elapsed)
        task.wait(0.2)
    end
end)()

-- Cancel button
closeButton.MouseButton1Click:Connect(function()
    isRunning = false
    statusLabel.Text = "Cancelled!"
    task.wait(1)
    screenGui:Destroy()
end)

-- Check writefile
if not writefile then
    statusLabel.Text = "ERROR: No writefile support"
    task.wait(3)
    screenGui:Destroy()
    return
end

-- Build list of services to dump (ALL SERVICES)
local servicesList = {}
local serviceNames = {}

if servicesToDump.Workspace then table.insert(servicesList, workspace) table.insert(serviceNames, "Workspace") end
if servicesToDump.ReplicatedStorage then pcall(function() table.insert(servicesList, game:GetService("ReplicatedStorage")) table.insert(serviceNames, "ReplicatedStorage") end) end
if servicesToDump.Players then pcall(function() table.insert(servicesList, game:GetService("Players")) table.insert(serviceNames, "Players") end) end
if servicesToDump.Lighting then pcall(function() table.insert(servicesList, game:GetService("Lighting")) table.insert(serviceNames, "Lighting") end) end
if servicesToDump.StarterGui then pcall(function() table.insert(servicesList, game:GetService("StarterGui")) table.insert(serviceNames, "StarterGui") end) end
if servicesToDump.StarterPack then pcall(function() table.insert(servicesList, game:GetService("StarterPack")) table.insert(serviceNames, "StarterPack") end) end
if servicesToDump.StarterPlayer then pcall(function() table.insert(servicesList, game:GetService("StarterPlayer")) table.insert(serviceNames, "StarterPlayer") end) end
if servicesToDump.Teams then pcall(function() table.insert(servicesList, game:GetService("Teams")) table.insert(serviceNames, "Teams") end) end
if servicesToDump.SoundService then pcall(function() table.insert(servicesList, game:GetService("SoundService")) table.insert(serviceNames, "SoundService") end) end
if servicesToDump.ReplicatedFirst then pcall(function() table.insert(servicesList, game:GetService("ReplicatedFirst")) table.insert(serviceNames, "ReplicatedFirst") end) end
if servicesToDump.ServerScriptService then pcall(function() table.insert(servicesList, game:GetService("ServerScriptService")) table.insert(serviceNames, "ServerScriptService") end) end
if servicesToDump.ServerStorage then pcall(function() table.insert(servicesList, game:GetService("ServerStorage")) table.insert(serviceNames, "ServerStorage") end) end
if servicesToDump.Chat then pcall(function() table.insert(servicesList, game:GetService("Chat")) table.insert(serviceNames, "Chat") end) end
if servicesToDump.TextChatService then pcall(function() table.insert(servicesList, game:GetService("TextChatService")) table.insert(serviceNames, "TextChatService") end) end
if servicesToDump.MaterialService then pcall(function() table.insert(servicesList, game:GetService("MaterialService")) table.insert(serviceNames, "MaterialService") end) end
if servicesToDump.LocalizationService then pcall(function() table.insert(servicesList, game:GetService("LocalizationService")) table.insert(serviceNames, "LocalizationService") end) end
if servicesToDump.VoiceChatService then pcall(function() table.insert(servicesList, game:GetService("VoiceChatService")) table.insert(serviceNames, "VoiceChatService") end) end
if servicesToDump.CoreGui then pcall(function() table.insert(servicesList, game:GetService("CoreGui")) table.insert(serviceNames, "CoreGui") end) end
if servicesToDump.CorePackages then pcall(function() table.insert(servicesList, game:GetService("CorePackages")) table.insert(serviceNames, "CorePackages") end) end

-- Update GUI with selected services
local serviceListStr = table.concat(serviceNames, ", ")
serviceListLabel.Text = "Dumping: " .. serviceListStr
print("[>] Selected services: " .. serviceListStr)
print("[>] Total services to dump: " .. #servicesList)

-- Clear file
writefile(outputFile, "")
statusLabel.Text = "Collecting instances from all services..."
task.wait(0.5)

-- COLLECT ALL INSTANCES FROM ALL SERVICES
local allInstances = {}
local totalCount = 0

for _, service in ipairs(servicesList) do
    if not isRunning then break end
    statusLabel.Text = "Scanning: " .. service.Name
    task.wait(0.1)
    
    -- Add the service itself
    totalCount = totalCount + 1
    table.insert(allInstances, service)
    
    -- Add all descendants
    for _, inst in ipairs(service:GetDescendants()) do
        if not isRunning then break end
        totalCount = totalCount + 1
        table.insert(allInstances, inst)
        if totalCount % 1000 == 0 then
            countLabel.Text = "Collecting: " .. totalCount .. " instances..."
            task.wait()
        end
    end
end

if not isRunning then
    screenGui:Destroy()
    return
end

-- Calculate estimates
local totalBatches = math.ceil(totalCount / INSTANCES_PER_BATCH)
local estSeconds = totalBatches * SECONDS_PER_BATCH

etaLabel.Text = "ETA: ~" .. formatTime(estSeconds)
statusLabel.Text = string.format("Found %d instances. Dumping %d services...", totalCount, #servicesList)
countLabel.Text = string.format("Instances: 0 / %d", totalCount)
task.wait(1)

-- Write header
local header = "=== FULL SERVICE DUMP ===\n"
header = header .. "Date: " .. os.date("%Y-%m-%d %H:%M:%S") .. "\n"
header = header .. "Services dumped (" .. #servicesList .. " services): " .. serviceListStr .. "\n"
header = header .. "Total instances: " .. totalCount .. "\n"
header = header .. "Batch size: " .. INSTANCES_PER_BATCH .. " every " .. SECONDS_PER_BATCH .. " seconds\n"
header = header .. "Estimated time: ~" .. formatTime(estSeconds) .. "\n"
header = header .. string.rep("=", 50) .. "\n\n"
writefile(outputFile, header)

-- DUMP IN BATCHES
local dumped = 0
local currentBatch = 0
local buffer = {}

local function flushBuffer()
    if #buffer > 0 then
        local current = readfile(outputFile) or ""
        writefile(outputFile, current .. table.concat(buffer, "\n") .. "\n")
        buffer = {}
    end
end

while dumped < totalCount and isRunning do
    currentBatch = currentBatch + 1
    local batchEnd = math.min(dumped + INSTANCES_PER_BATCH, totalCount)
    
    statusLabel.Text = string.format("Batch %d/%d - Processing...", currentBatch, totalBatches)
    
    -- Process this batch
    for i = dumped + 1, batchEnd do
        local inst = allInstances[i]
        local depth = inst:GetDepth()
        local indent = string.rep("  ", depth)
        local name = inst.Name
        if name == "" then name = "[Unnamed]" end
        local line = indent .. name .. " (" .. inst.ClassName .. ")"
        table.insert(buffer, line)
        dumped = dumped + 1
    end
    
    -- Update GUI
    local percent = (dumped / totalCount) * 100
    countLabel.Text = string.format("Instances: %d / %d", dumped, totalCount)
    percentLabel.Text = string.format("%.1f%% complete", percent)
    progressFill.Size = UDim2.new(percent / 100, 0, 1, 0)
    
    -- Update ETA based on actual speed
    local elapsed = tick() - startTime
    local rate = dumped / elapsed
    local remaining = totalCount - dumped
    local etaRemaining = remaining / rate
    etaLabel.Text = "ETA: " .. formatTime(etaRemaining)
    
    -- Save to file
    flushBuffer()
    
    -- Wait before next batch (unless done)
    if dumped < totalCount and isRunning then
        for waitSec = 1, SECONDS_PER_BATCH do
            if not isRunning then break end
            statusLabel.Text = string.format("Batch %d/%d done. Waiting %ds...", currentBatch, totalBatches, SECONDS_PER_BATCH - waitSec + 1)
            task.wait(1)
        end
    end
end

-- Final save
flushBuffer()

local elapsed = tick() - startTime
local fileSize = (readfile(outputFile) or ""):len() / 1024

-- Completion
statusLabel.Text = "COMPLETE!"
etaLabel.Text = "Done in " .. formatTime(elapsed)
countLabel.Text = "Total: " .. dumped .. " instances"
percentLabel.Text = "100% complete"
progressFill.Size = UDim2.new(1, 0, 1, 0)
timerLabel.Text = "Done! " .. formatTime(elapsed)

print("\n========== FULL SERVICE DUMP COMPLETE ==========")
print("Saved to: " .. outputFile)
print("Services dumped (" .. #servicesList .. " services): " .. serviceListStr)
print("Total instances: " .. dumped)
print("Time: " .. formatTime(elapsed))
print("File size: " .. string.format("%.2f", fileSize) .. " KB")
print("================================================")

task.wait(5)
screenGui:Destroy()
