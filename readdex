--[[
    GUI TIMER EXPLORER DUMPER
    - Shows a GUI with timer and progress
    - Takes approximately 5 minutes
    - Saves to file
--]]

local outputFile = "game_explorer_dump.txt"
local startTime = tick()
local targetSeconds = 300 -- 5 minutes
local totalInstances = 0
local isRunning = true

-- Check for writefile support
if not writefile then
    print("[!] This executor doesn't support writefile.")
    return
end

-- Clear/create file
writefile(outputFile, "")

-- ============ CREATE GUI ============
local screenGui = Instance.new("ScreenGui")
local mainFrame = Instance.new("Frame")
local titleLabel = Instance.new("TextLabel")
local timerLabel = Instance.new("TextLabel")
local statusLabel = Instance.new("TextLabel")
local progressBar = Instance.new("Frame")
local progressFill = Instance.new("Frame")
local instanceCountLabel = Instance.new("TextLabel")
local closeButton = Instance.new("TextButton")

-- Properties
screenGui.Name = "ExplorerDumperGUI"
screenGui.Parent = game:GetService("CoreGui")
pcall(function() screenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui") end)

mainFrame.Size = UDim2.new(0, 400, 0, 250)
mainFrame.Position = UDim2.new(0.5, -200, 0.5, -125)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
mainFrame.BorderSizePixel = 0
mainFrame.BackgroundTransparency = 0.1
mainFrame.Parent = screenGui

-- Title
titleLabel.Size = UDim2.new(1, 0, 0, 40)
titleLabel.Position = UDim2.new(0, 0, 0, 0)
titleLabel.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
titleLabel.Text = "Explorer Dumper"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.TextSize = 20
titleLabel.Font = Enum.Font.GothamBold
titleLabel.Parent = mainFrame

-- Timer Label
timerLabel.Size = UDim2.new(1, 0, 0, 60)
timerLabel.Position = UDim2.new(0, 0, 0, 50)
timerLabel.BackgroundTransparency = 1
timerLabel.Text = "Time Remaining: 5:00"
timerLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
timerLabel.TextSize = 28
timerLabel.Font = Enum.Font.GothamBold
timerLabel.Parent = mainFrame

-- Status Label
statusLabel.Size = UDim2.new(1, 0, 0, 30)
statusLabel.Position = UDim2.new(0, 0, 0, 110)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Starting dump..."
statusLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
statusLabel.TextSize = 14
statusLabel.Font = Enum.Font.Gotham
statusLabel.Parent = mainFrame

-- Progress Bar Background
progressBar.Size = UDim2.new(0.9, 0, 0, 20)
progressBar.Position = UDim2.new(0.05, 0, 0, 150)
progressBar.BackgroundColor3 = Color3.fromRGB(60, 60, 70)
progressBar.BorderSizePixel = 0
progressBar.Parent = mainFrame

-- Progress Bar Fill
progressFill.Size = UDim2.new(0, 0, 1, 0)
progressFill.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
progressFill.BorderSizePixel = 0
progressFill.Parent = progressBar

-- Instance Count Label
instanceCountLabel.Size = UDim2.new(1, 0, 0, 30)
instanceCountLabel.Position = UDim2.new(0, 0, 0, 180)
instanceCountLabel.BackgroundTransparency = 1
instanceCountLabel.Text = "Instances dumped: 0"
instanceCountLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
instanceCountLabel.TextSize = 12
instanceCountLabel.Font = Enum.Font.Gotham
instanceCountLabel.Parent = mainFrame

-- Close Button
closeButton.Size = UDim2.new(0, 80, 0, 30)
closeButton.Position = UDim2.new(0.5, -40, 0, 215)
closeButton.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
closeButton.Text = "Cancel"
closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
closeButton.TextSize = 14
closeButton.Font = Enum.Font.GothamBold
closeButton.Parent = mainFrame

-- ============ UPDATE TIMER FUNCTION ============
local function updateTimer()
    while isRunning and screenGui and screenGui.Parent do
        local elapsed = tick() - startTime
        local remaining = math.max(0, targetSeconds - elapsed)
        local minutes = math.floor(remaining / 60)
        local seconds = math.floor(remaining % 60)
        
        timerLabel.Text = string.format("Time Remaining: %d:%02d", minutes, seconds)
        
        -- Update progress bar (based on time)
        local progress = math.min(1, elapsed / targetSeconds)
        progressFill.Size = UDim2.new(progress, 0, 1, 0)
        
        -- Change color based on progress
        if progress < 0.33 then
            progressFill.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
        elseif progress < 0.66 then
            progressFill.BackgroundColor3 = Color3.fromRGB(255, 200, 100)
        else
            progressFill.BackgroundColor3 = Color3.fromRGB(255, 100, 100)
        end
        
        task.wait(0.1)
    end
end

-- ============ DUMP FUNCTION ============
local lineBuffer = {}
local batchSize = 10

local function flushBuffer()
    if #lineBuffer > 0 then
        local current = readfile(outputFile) or ""
        writefile(outputFile, current .. table.concat(lineBuffer, "\n") .. "\n")
        lineBuffer = {}
    end
end

local function dumpExplorer(instance, indentLevel)
    if not isRunning then return end
    
    local indent = string.rep("  ", indentLevel)
    local displayName = instance.Name ~= "" and instance.Name or "[Unnamed]"
    local line = indent .. displayName .. " (" .. instance.ClassName .. ")"
    
    table.insert(lineBuffer, line)
    totalInstances = totalInstances + 1
    
    -- Update GUI every 100 instances
    if totalInstances % 100 == 0 then
        instanceCountLabel.Text = "Instances dumped: " .. totalInstances
        statusLabel.Text = "Dumping: " .. instance.ClassName
    end
    
    if #lineBuffer >= batchSize then
        flushBuffer()
    end
    
    -- Slow down to hit 5 minutes
    task.wait(0.003)
    
    local children = instance:GetChildren()
    for _, child in ipairs(children) do
        if not isRunning then break end
        dumpExplorer(child, indentLevel + 1)
    end
end

-- ============ START DUMP ============
statusLabel.Text = "Starting dump..."
task.wait(0.5)

-- Start timer update thread
coroutine.wrap(updateTimer)()

-- Write header
lineBuffer = {}
table.insert(lineBuffer, "=== COMPLETE GAME EXPLORER (5-min dump) ===")
table.insert(lineBuffer, "Game (DataModel)")
flushBuffer()

-- Dump each service
local services = game:GetChildren()
local totalServices = #services

for index, service in ipairs(services) do
    if not isRunning then break end
    
    statusLabel.Text = "Dumping service: " .. service.Name
    dumpExplorer(service, 1)
    
    if index < totalServices and isRunning then
        task.wait(0.5)
    end
end

-- Final flush
flushBuffer()

local elapsedTime = tick() - startTime
local fileSize = (readfile(outputFile) or ""):len() / 1024

-- ============ SHOW COMPLETION ============
if isRunning then
    statusLabel.Text = "COMPLETE! Saved to file"
    titleLabel.Text = "Dump Complete!"
    timerLabel.Text = "Complete! " .. string.format("%.1f", elapsedTime/60) .. " minutes"
    progressFill.Size = UDim2.new(1, 0, 1, 0)
    progressFill.BackgroundColor3 = Color3.fromRGB(100, 200, 100)
    instanceCountLabel.Text = "Total instances: " .. totalInstances .. " | Size: " .. string.format("%.2f", fileSize) .. " KB"
    
    print("\n[✓] DUMP COMPLETE")
    print("[✓] Total instances: " .. totalInstances)
    print("[✓] Time taken: " .. math.floor(elapsedTime) .. " seconds (" .. string.format("%.1f", elapsedTime/60) .. " minutes)")
    print("[✓] File size: " .. string.format("%.2f", fileSize) .. " KB")
    print("[✓] Saved to: " .. outputFile)
    
    -- Close GUI after 5 seconds
    task.wait(5)
end

-- Close button functionality
closeButton.MouseButton1Click:Connect(function()
    isRunning = false
    statusLabel.Text = "Cancelled by user"
    timerLabel.Text = "Cancelled"
    titleLabel.Text = "Cancelled"
    task.wait(1)
    if screenGui then screenGui:Destroy() end
end)

-- Auto-close after completion
task.wait(5)
if screenGui then screenGui:Destroy() end
