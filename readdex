--[[
    SIMPLE FAST DUMPER
    - Only dumps specific services
    - Saves to C:\Users\RYZEN7 GAMER\New Folder
    - Timer + instance count only (no ETA/progress bar)
--]]

-- ========== SAVE PATH ==========
local outputFile = "C:\\Users\\RYZEN7 GAMER\\New Folder\\game_dump.txt"
local startTime = tick()
local totalInstances = 0
local isRunning = true

-- ========== ONLY THESE SERVICES ==========
local servicesToDump = {
    "Workspace",
    "ReplicatedStorage",
    "Players",
    "Lighting",
    "StarterGui",
    "StarterPack",
    "StarterPlayer",
    "Teams",
    "SoundService",
    "ReplicatedFirst",
    "ServerScriptService",
    "ServerStorage",
    "Chat",
    "TextChatService",
}

-- Check for writefile support
if not writefile then
    print("[!] This executor doesn't support writefile.")
    return
end

-- Clear/create file
writefile(outputFile, "")

-- ============ CREATE SIMPLE GUI ============
local screenGui = Instance.new("ScreenGui")
local mainFrame = Instance.new("Frame")
local titleLabel = Instance.new("TextLabel")
local timerLabel = Instance.new("TextLabel")
local statusLabel = Instance.new("TextLabel")
local instanceCountLabel = Instance.new("TextLabel")
local closeButton = Instance.new("TextButton")

screenGui.Name = "SimpleDumperGUI"
screenGui.Parent = game:GetService("CoreGui")
pcall(function() screenGui.Parent = game.Players.LocalPlayer:WaitForChild("PlayerGui") end)

mainFrame.Size = UDim2.new(0, 350, 0, 200)
mainFrame.Position = UDim2.new(0.5, -175, 0.5, -100)
mainFrame.BackgroundColor3 = Color3.fromRGB(30, 30, 40)
mainFrame.BackgroundTransparency = 0.1
mainFrame.Parent = screenGui

titleLabel.Size = UDim2.new(1, 0, 0, 40)
titleLabel.Position = UDim2.new(0, 0, 0, 0)
titleLabel.BackgroundColor3 = Color3.fromRGB(50, 50, 70)
titleLabel.Text = "Fast Explorer Dumper"
titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
titleLabel.TextSize = 18
titleLabel.Font = Enum.Font.GothamBold
titleLabel.Parent = mainFrame

timerLabel.Size = UDim2.new(1, 0, 0, 50)
timerLabel.Position = UDim2.new(0, 0, 0, 45)
timerLabel.BackgroundTransparency = 1
timerLabel.Text = "Time: 0:00"
timerLabel.TextColor3 = Color3.fromRGB(255, 200, 100)
timerLabel.TextSize = 24
timerLabel.Font = Enum.Font.GothamBold
timerLabel.Parent = mainFrame

statusLabel.Size = UDim2.new(1, 0, 0, 30)
statusLabel.Position = UDim2.new(0, 0, 0, 95)
statusLabel.BackgroundTransparency = 1
statusLabel.Text = "Starting dump..."
statusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
statusLabel.TextSize = 13
statusLabel.Parent = mainFrame

instanceCountLabel.Size = UDim2.new(1, 0, 0, 30)
instanceCountLabel.Position = UDim2.new(0, 0, 0, 125)
instanceCountLabel.BackgroundTransparency = 1
instanceCountLabel.Text = "Instances: 0"
instanceCountLabel.TextColor3 = Color3.fromRGB(150, 150, 150)
instanceCountLabel.TextSize = 12
instanceCountLabel.Parent = mainFrame

closeButton.Size = UDim2.new(0, 80, 0, 30)
closeButton.Position = UDim2.new(0.5, -40, 0, 160)
closeButton.BackgroundColor3 = Color3.fromRGB(200, 60, 60)
closeButton.Text = "Cancel"
closeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
closeButton.TextSize = 14
closeButton.Font = Enum.Font.GothamBold
closeButton.Parent = mainFrame

-- Timer update (simple, just shows elapsed time)
coroutine.wrap(function()
    while isRunning and screenGui and screenGui.Parent do
        local elapsed = tick() - startTime
        local minutes = math.floor(elapsed / 60)
        local seconds = math.floor(elapsed % 60)
        timerLabel.Text = string.format("Time: %d:%02d", minutes, seconds)
        task.wait(0.2)
    end
end)()

-- Cancel button
closeButton.MouseButton1Click:Connect(function()
    isRunning = false
    statusLabel.Text = "Cancelled!"
    task.wait(1)
    screenGui:Destroy()
end)

-- ============ FAST DUMP FUNCTION ============
local buffer = {}
local batchSize = 50  -- Larger batch = faster

local function flushBuffer()
    if #buffer > 0 then
        local current = readfile(outputFile) or ""
        writefile(outputFile, current .. table.concat(buffer, "\n") .. "\n")
        buffer = {}
    end
end

local function dumpFast(instance, depth)
    if not isRunning then return end
    
    local indent = string.rep("  ", depth)
    local name = instance.Name ~= "" and instance.Name or "[Unnamed]"
    local line = indent .. name .. " (" .. instance.ClassName .. ")"
    
    table.insert(buffer, line)
    totalInstances = totalInstances + 1
    
    -- Update GUI every 200 instances (less frequent = faster)
    if totalInstances % 200 == 0 then
        instanceCountLabel.Text = "Instances: " .. totalInstances
        statusLabel.Text = "Dumping: " .. instance.ClassName
        task.wait() -- Small pause to keep GUI responsive
    end
    
    if #buffer >= batchSize then
        flushBuffer()
    end
    
    -- FASTER: removed the 0.003 second delay
    for _, child in ipairs(instance:GetChildren()) do
        dumpFast(child, depth + 1)
    end
end

-- ============ START DUMP ============
statusLabel.Text = "Starting dump..."
instanceCountLabel.Text = "Instances: 0"
task.wait(0.5)

-- Write header
buffer = {}
table.insert(buffer, "=== GAME EXPLORER DUMP (Selected Services) ===")
table.insert(buffer, "Game (DataModel)")
flushBuffer()

-- Dump ONLY selected services
local dumpedServices = 0
for _, serviceName in ipairs(servicesToDump) do
    if not isRunning then break end
    
    local success, service = pcall(function()
        return game:GetService(serviceName)
    end)
    
    if success and service then
        dumpedServices = dumpedServices + 1
        statusLabel.Text = "Dumping: " .. serviceName
        dumpFast(service, 1)
        task.wait(0.1) -- Small pause between services
    else
        print("[!] Service not found: " .. serviceName)
    end
end

-- Final flush
flushBuffer()

local elapsedTime = tick() - startTime
local minutes = math.floor(elapsedTime / 60)
local seconds = math.floor(elapsedTime % 60)
local fileSize = (readfile(outputFile) or ""):len() / 1024

-- ============ SHOW COMPLETION ============
if isRunning then
    statusLabel.Text = "COMPLETE!"
    titleLabel.Text = "Dump Complete!"
    timerLabel.Text = string.format("Done! %d:%02d", minutes, seconds)
    instanceCountLabel.Text = string.format("Total: %d instances (%.1f KB)", totalInstances, fileSize)
    
    print("\n[✓] DUMP COMPLETE")
    print("[✓] Total instances: " .. totalInstances)
    print("[✓] Time taken: " .. minutes .. "m " .. seconds .. "s")
    print("[✓] File size: " .. string.format("%.2f", fileSize) .. " KB")
    print("[✓] Saved to: " .. outputFile)
    
    -- Close GUI after 4 seconds
    task.wait(4)
end

-- Auto-close
if screenGui then screenGui:Destroy() end
