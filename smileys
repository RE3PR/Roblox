-- Roblox Executor Script: Find all RemoteEvents/RemoteFunctions and other server-save mechanisms
-- This script scans the entire game hierarchy, lists all relevant instances,
-- and copies the results to your clipboard.

-- Helper function to get full path of an instance
local function getFullPath(instance)
    local path = instance.Name
    local parent = instance.Parent
    while parent do
        path = parent.Name .. "/" .. path
        parent = parent.Parent
    end
    return path
end

-- Helper function to check if an instance is a remote that can send data to server
local function isServerSavingRemote(instance)
    local className = instance.ClassName
    return className == "RemoteEvent" or className == "RemoteFunction"
    -- Note: UnreliableRemoteEvent also exists but is similar; add if needed
    -- Also, BindableEvent/BindableFunction are client-only, so not included.
end

-- Main collection
local findings = {
    remotes = {},      -- list of remote objects
    others = {}        -- any other potential server-save mechanisms (e.g., custom objects)
}

-- Recursively traverse all instances
local function scan(instance)
    if isServerSavingRemote(instance) then
        table.insert(findings.remotes, {
            name = instance.Name,
            className = instance.ClassName,
            path = getFullPath(instance)
        })
    end
    -- Check for custom named objects that might be used as remotes (unlikely but thorough)
    if instance:IsA("Instance") and (instance.Name:lower():find("save") or instance.Name:lower():find("data")) then
        table.insert(findings.others, {
            name = instance.Name,
            className = instance.ClassName,
            path = getFullPath(instance)
        })
    end
    -- Recursively scan children
    for _, child in ipairs(instance:GetChildren()) do
        scan(child)
    end
end

-- Start scanning from game roots
local roots = {game.Workspace, game.ReplicatedStorage, game.Lighting, game.ServerStorage, game.Players, game.StarterGui, game.StarterPack, game.StarterPlayer}
for _, root in ipairs(roots) do
    if root then
        scan(root)
    end
end

-- Build output string
local outputLines = {}
table.insert(outputLines, "=== REMOTEEVENTS & REMOTEFUNCTIONS ===")
if #findings.remotes == 0 then
    table.insert(outputLines, "None found.")
else
    for _, remote in ipairs(findings.remotes) do
        table.insert(outputLines, string.format("[%s] %s : %s", remote.className, remote.name, remote.path))
    end
end

table.insert(outputLines, "\n=== POTENTIAL SAVE-RELATED INSTANCES (by name) ===")
if #findings.others == 0 then
    table.insert(outputLines, "None found.")
else
    for _, obj in ipairs(findings.others) do
        table.insert(outputLines, string.format("[%s] %s : %s", obj.className, obj.name, obj.path))
    end
end

-- Add note about other server-save methods (client-side limitations)
table.insert(outputLines, "\n=== NOTES ===")
table.insert(outputLines, "1. RemoteEvent: Use :FireServer() to send data to server.")
table.insert(outputLines, "2. RemoteFunction: Use :InvokeServer() to send data and receive a response.")
table.insert(outputLines, "3. On the client, you cannot directly call DataStoreService or other server-only services.")
table.insert(outputLines, "4. The server must have handlers listening to these remotes for any data to be saved.")
table.insert(outputLines, "5. Check if any HttpService POST requests are made (but that's external, not game server).")
table.insert(outputLines, "6. Also watch for custom events via BindableEvent (client-only) - they cannot save to server.")

local finalOutput = table.concat(outputLines, "\n")

-- Output to console
print(finalOutput)

-- Copy to clipboard (executor-specific)
if setclipboard then
    setclipboard(finalOutput)
    print("\n[✓] Results copied to clipboard.")
elseif toclipboard then
    toclipboard(finalOutput)
    print("\n[✓] Results copied to clipboard.")
else
    print("\n[!] Clipboard function not found. Please copy manually.")
end

-- Also return the output if executor supports returning
return finalOutput
