--[[
    Auto-Eat GUI with teleport to map center.
    Press "Start" → teleport, set eat speed, and begin fast auto-eat (10ms loop).
    Press "Stop" or "X" key → stop auto-eating.
--]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")

local player = Players.LocalPlayer
local character = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = character:WaitForChild("HumanoidRootPart")

-- ========== 1. FIND MAP CENTER ==========
local function getMapCenter()
    -- Try to find a part named "Center" or use the average of all parts inside a "Map" folder.
    local centerPart = Workspace:FindFirstChild("Center")
    if centerPart and centerPart:IsA("BasePart") then
        return centerPart.Position
    end

    local mapFolder = Workspace:FindFirstChild("Map")
    if mapFolder and mapFolder:IsA("Folder") then
        local total = Vector3.new(0,0,0)
        local count = 0
        for _, child in ipairs(mapFolder:GetDescendants()) do
            if child:IsA("BasePart") then
                total = total + child.Position
                count = count + 1
            end
        end
        if count > 0 then
            return total / count
        end
    end

    -- Fallback: raycast from (0, 500, 0) downward to find ground
    local rayParams = RaycastParams.new()
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.FilterDescendantsInstances = {character}
    local rayResult = Workspace:Raycast(Vector3.new(0, 500, 0), Vector3.new(0, -1000, 0), rayParams)
    if rayResult then
        return Vector3.new(0, rayResult.Position.Y + 3, 0)
    end
    return Vector3.new(0, 50, 0)   -- final fallback
end

-- ========== 2. SET EAT SPEED TO 100 ==========
local function setEatSpeed()
    -- Find EatSpeed NumberValue (from the datamodel: Player > Upgrades > EatSpeed)
    local upgrades = player:FindFirstChild("Upgrades")
    if upgrades then
        local eatSpeed = upgrades:FindFirstChild("EatSpeed")
        if eatSpeed and eatSpeed:IsA("NumberValue") then
            eatSpeed.Value = 100
            warn("Set EatSpeed to 100")
        else
            warn("EatSpeed NumberValue not found under Upgrades")
        end
    else
        warn("Upgrades folder not found in player")
    end
end

-- ========== 3. TELEPORT TO CENTER ==========
local function teleportToCenter()
    local center = getMapCenter()
    if humanoidRootPart and humanoidRootPart.Parent then
        humanoidRootPart.CFrame = CFrame.new(center)
        task.wait(0.1)  -- brief pause to let physics settle
    end
end

-- ========== 4. FIND THE "EAT" REMOTE EVENT ==========
local eatRemote = nil
local function findEatRemote()
    -- Common locations for the eat remote
    local possibleParents = {
        ReplicatedStorage,
        game:GetService("ReplicatedFirst"),
        player:FindFirstChild("PlayerScripts"),
        character,
        Workspace
    }
    for _, parent in ipairs(possibleParents) do
        if parent then
            local remote = parent:FindFirstChild("Eat") or parent:FindFirstChild("EatTarget") or parent:FindFirstChild("Consume")
            if remote and remote:IsA("RemoteEvent") then
                eatRemote = remote
                return
            end
        end
    end
    -- If still not found, search the entire DataModel (expensive, but one-time)
    for _, obj in ipairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") and (obj.Name == "Eat" or obj.Name == "EatTarget" or obj.Name == "Consume") then
            eatRemote = obj
            break
        end
    end
    if not eatRemote then
        warn("Could not find any eat RemoteEvent. Auto-eat will not work.")
    end
end

-- ========== 5. FIND THE NEAREST EDIBLE TARGET ==========
local function getNearestEdible()
    local rootPos = humanoidRootPart and humanoidRootPart.Position
    if not rootPos then return nil end

    local closest = nil
    local closestDist = math.huge

    -- Option A: Other players (if EatPlayers is enabled)
    local preferences = player:FindFirstChild("Preferences")
    local eatPlayers = preferences and preferences:FindFirstChild("Eat Players")
    if eatPlayers and eatPlayers:IsA("BoolValue") and eatPlayers.Value then
        for _, other in ipairs(Players:GetPlayers()) do
            if other ~= player then
                local otherChar = other.Character
                if otherChar and otherChar:FindFirstChild("HumanoidRootPart") and otherChar.Humanoid and otherChar.Humanoid.Health > 0 then
                    local dist = (otherChar.HumanoidRootPart.Position - rootPos).Magnitude
                    if dist < closestDist and dist < 20 then  -- range limit
                        closest = otherChar.HumanoidRootPart
                        closestDist = dist
                    end
                end
            end
        end
    end

    -- Option B: Edible parts (e.g., tokens, fragments, food)
    -- Look for parts with a specific tag or name pattern
    local edibleTags = {"Fragmentable", "Token", "Food", "Edible"}
    for _, tag in ipairs(edibleTags) do
        for _, part in ipairs(Workspace:GetDescendants()) do
            if part:IsA("BasePart") and (part.Name:find(tag) or part:GetAttribute("Edible")) then
                local dist = (part.Position - rootPos).Magnitude
                if dist < closestDist and dist < 30 then
                    closest = part
                    closestDist = dist
                end
            end
        end
    end

    return closest
end

-- ========== 6. AUTO-EAT LOOP (10ms interval) ==========
local eating = false
local eatConnection = nil

local function startAutoEat()
    if eatConnection then return end
    if not eatRemote then
        warn("No eat remote found. Auto-eat cannot start.")
        return
    end

    eating = true
    -- Run every 0.01 seconds (10ms)
    eatConnection = RunService.Heartbeat:Connect(function()
        if not eating then return end
        if not character or not character.Parent then
            character = player.Character
            if not character then return end
            humanoidRootPart = character:FindFirstChild("HumanoidRootPart")
            if not humanoidRootPart then return end
        end

        local target = getNearestEdible()
        if target and eatRemote then
            -- Fire the remote to eat the target
            -- Common signature: remote:FireServer(target) or remote:FireServer(target, ...)
            pcall(function()
                eatRemote:FireServer(target)
            end)
        end
    end)
end

local function stopAutoEat()
    eating = false
    if eatConnection then
        eatConnection:Disconnect()
        eatConnection = nil
    end
end

-- ========== 7. GUI & KEYBINDS ==========
local function setupGui()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AutoEatGUI"
    screenGui.Parent = player:WaitForChild("PlayerGui")

    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 200, 0, 100)
    mainFrame.Position = UDim2.new(0.5, -100, 0.5, -50)
    mainFrame.BackgroundColor3 = Color3.fromRGB(30,30,30)
    mainFrame.BackgroundTransparency = 0.2
    mainFrame.BorderSizePixel = 0
    mainFrame.Parent = screenGui

    local startBtn = Instance.new("TextButton")
    startBtn.Size = UDim2.new(0, 80, 0, 40)
    startBtn.Position = UDim2.new(0, 10, 0, 10)
    startBtn.Text = "Start"
    startBtn.BackgroundColor3 = Color3.fromRGB(0,200,0)
    startBtn.Parent = mainFrame
    startBtn.MouseButton1Click:Connect(function()
        -- Teleport, set speed, then start eating
        teleportToCenter()
        setEatSpeed()
        startAutoEat()
    end)

    local stopBtn = Instance.new("TextButton")
    stopBtn.Size = UDim2.new(0, 80, 0, 40)
    stopBtn.Position = UDim2.new(0, 110, 0, 10)
    stopBtn.Text = "Stop (X)"
    stopBtn.BackgroundColor3 = Color3.fromRGB(200,0,0)
    stopBtn.Parent = mainFrame
    stopBtn.MouseButton1Click:Connect(function()
        stopAutoEat()
    end)

    local statusLabel = Instance.new("TextLabel")
    statusLabel.Size = UDim2.new(0, 180, 0, 20)
    statusLabel.Position = UDim2.new(0, 10, 0, 60)
    statusLabel.Text = "Idle"
    statusLabel.TextColor3 = Color3.new(1,1,1)
    statusLabel.BackgroundTransparency = 1
    statusLabel.Parent = mainFrame

    -- Update status text
    local oldStart = startAutoEat
    local oldStop = stopAutoEat
    _G.startAutoEat = function()
        oldStart()
        statusLabel.Text = "Auto-eating (10ms)"
    end
    _G.stopAutoEat = function()
        oldStop()
        statusLabel.Text = "Stopped"
    end
    startAutoEat = _G.startAutoEat
    stopAutoEat = _G.stopAutoEat

    -- Bind X key to stop
    local inputConnection
    inputConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed then return end
        if input.KeyCode == Enum.KeyCode.X then
            stopAutoEat()
        end
    end)
end

-- Wait for character and remote, then setup GUI
player.CharacterAdded:Connect(function(newChar)
    character = newChar
    humanoidRootPart = character:WaitForChild("HumanoidRootPart")
end)

findEatRemote()
setupGui()
