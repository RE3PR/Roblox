--[[
    Roblox Executor Script: Find all RemoteEvents/RemoteFunctions + potential server-save mechanisms
    - Safely handles missing services (like ServerStorage)
    - Copies everything to clipboard
--]]

local function getFullPath(instance)
    local parts = {}
    local current = instance
    while current do
        table.insert(parts, 1, current.Name)
        current = current.Parent
    end
    return table.concat(parts, "/")
end

local function isRemote(instance)
    local class = instance.ClassName
    return class == "RemoteEvent" or class == "RemoteFunction" or class == "UnreliableRemoteEvent"
end

-- Collect findings
local remotes = {}
local saveRelated = {}

-- Recursive scanner
local function scan(instance)
    if isRemote(instance) then
        table.insert(remotes, {
            name = instance.Name,
            class = instance.ClassName,
            path = getFullPath(instance)
        })
    end
    -- Also catch any instance with "save" or "data" in name (custom server-save attempts)
    local lowerName = instance.Name:lower()
    if lowerName:find("save") or lowerName:find("data") then
        table.insert(saveRelated, {
            name = instance.Name,
            class = instance.ClassName,
            path = getFullPath(instance)
        })
    end
    for _, child in ipairs(instance:GetChildren()) do
        scan(child)
    end
end

-- Define possible root containers (only those that actually exist)
local potentialRoots = {
    game.Workspace,
    game.ReplicatedStorage,
    game.Lighting,
    game.Players,
    game.StarterGui,
    game.StarterPack,
    game.StarterPlayer
}
-- Also check ServerStorage and ServerScriptService if they exist (they often don't on client)
if game:FindFirstChild("ServerStorage") then
    table.insert(potentialRoots, game.ServerStorage)
end
if game:FindFirstChild("ServerScriptService") then
    table.insert(potentialRoots, game.ServerScriptService)
end

-- Scan each existing root
for _, root in ipairs(potentialRoots) do
    if root then
        scan(root)
    end
end

-- Also scan the entire game (catches anything in weird places like CoreGui)
scan(game)

-- Build output
local lines = {}
table.insert(lines, "=== REMOTES (can send data to server) ===")
if #remotes == 0 then
    table.insert(lines, "None found.")
else
    for _, r in ipairs(remotes) do
        table.insert(lines, string.format("[%s] %s -> %s", r.class, r.name, r.path))
    end
end

table.insert(lines, "\n=== INSTANCES WITH 'save' OR 'data' IN NAME ===")
if #saveRelated == 0 then
    table.insert(lines, "None found.")
else
    for _, s in ipairs(saveRelated) do
        table.insert(lines, string.format("[%s] %s -> %s", s.class, s.name, s.path))
    end
end

table.insert(lines, "\n=== HOW TO SEND DATA TO SERVER (Client → Server) ===")
table.insert(lines, "• RemoteEvent: remote:FireServer(data)")
table.insert(lines, "• RemoteFunction: remote:InvokeServer(data)")
table.insert(lines, "• You cannot call DataStoreService or HttpService from client.")
table.insert(lines, "• The server must have matching .OnServerEvent / .OnServerInvoke handlers.")

local finalOutput = table.concat(lines, "\n")
print(finalOutput)

-- Copy to clipboard
if setclipboard then
    setclipboard(finalOutput)
    print("\n[✓] Copied to clipboard (setclipboard).")
elseif toclipboard then
    toclipboard(finalOutput)
    print("\n[✓] Copied to clipboard (toclipboard).")
else
    print("\n[!] No clipboard function found. Copy manually.")
end

return finalOutput
