-- Remote Enumeration & Clipboard Export Script
-- Scans: ReplicatedStorage, Workspace, Players.LocalPlayer, Lighting, StarterGui, StarterPack, etc.

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local Lighting = game:GetService("Lighting")
local StarterGui = game:GetService("StarterGui")
local StarterPack = game:GetService("StarterPack")
local player = Players.LocalPlayer

-- Helper to collect all relevant objects from a container recursively
local function collectRemotes(container, list, path)
    path = path or container:GetFullName()
    for _, child in ipairs(container:GetChildren()) do
        local childPath = path .. "." .. child.Name
        if child:IsA("RemoteEvent") or child:IsA("RemoteFunction") or 
           child:IsA("BindableEvent") or child:IsA("BindableFunction") then
            table.insert(list, {
                Type = child.ClassName,
                Path = childPath,
                Object = child
            })
        end
        -- Recurse into non-service folders (avoid massive recursion into services)
        if child:IsA("Folder") or child:IsA("Model") or child:IsA("Configuration") then
            collectRemotes(child, list, childPath)
        end
    end
end

-- Main collection table
local allRemotes = {}

-- Scan common containers
local containersToScan = {
    ReplicatedStorage,
    Workspace,
    player, -- Player instance (PlayerGui, Backpack, PlayerScripts, etc.)
    Lighting,
    StarterGui,
    StarterPack,
}

-- Also scan the DataModel root (game) but limit depth to avoid massive output
collectRemotes(game, allRemotes, "game")

-- Remove duplicates by path (some objects may appear multiple times if containers overlap)
local uniqueRemotes = {}
local seenPaths = {}
for _, entry in ipairs(allRemotes) do
    if not seenPaths[entry.Path] then
        seenPaths[entry.Path] = true
        table.insert(uniqueRemotes, entry)
    end
end

-- Sort by type then path
table.sort(uniqueRemotes, function(a, b)
    if a.Type == b.Type then
        return a.Path < b.Path
    else
        return a.Type < b.Type
    end
end)

-- Build output string
local outputLines = {"=== REMOTE EVENTS / FUNCTIONS / BINDABLES ===\n"}
local typeGroups = {}
for _, entry in ipairs(uniqueRemotes) do
    if not typeGroups[entry.Type] then
        typeGroups[entry.Type] = {}
    end
    table.insert(typeGroups[entry.Type], entry.Path)
end

for _, typeName in ipairs({"RemoteEvent", "RemoteFunction", "BindableEvent", "BindableFunction"}) do
    local paths = typeGroups[typeName]
    if paths then
        table.insert(outputLines, string.format("\n-- %s (%d) --", typeName, #paths))
        for _, path in ipairs(paths) do
            table.insert(outputLines, path)
        end
    end
end

local outputText = table.concat(outputLines, "\n")

-- Print to console
print(outputText)

-- Copy to clipboard (supports common exploit executors)
local success, err = pcall(function()
    if setclipboard then
        setclipboard(outputText)
    elseif syn and syn.write_clipboard then
        syn.write_clipboard(outputText)
    elseif write_clipboard then
        write_clipboard(outputText)
    else
        error("No clipboard function found")
    end
end)

if success then
    print("\n✅ List copied to clipboard!")
else
    print("\n⚠️ Could not copy to clipboard: " .. tostring(err))
    print("Manual copy the output above.")
end
