    coreGui:FindFirstChild("RobloxGui"):FindFirstChild("SmileysEvent"),
    workspace:FindFirstChild("SmileysEvent"),
    game:FindFirstChild("SmileysEvent", true)
}

for _, loc in pairs(searchLocations) do
    if loc then
        smileysEvent = loc
        break
    end
end

-- Deep search if not found
if not smileysEvent then
    local function deepSearch(inst, maxDepth)
        if maxDepth and maxDepth <= 0 then return nil end
        if inst.Name == "SmileysEvent" then return inst end
        for _, child in pairs(inst:GetChildren()) do
            local found = deepSearch(child, (maxDepth or 20) - 1)
            if found then return found end
        end
        return nil
    end
    smileysEvent = deepSearch(game, 20)
end

