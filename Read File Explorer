-- Function to format numbers with commas
local function formatNumber(num)
    return tostring(num):reverse():gsub("%d%d%d", "%1,"):reverse():gsub("^,", "")
end

-- Count instances
local function countInstances()
    statusLabel.Text = "Counting instances (this may take a moment)..."
    task.wait(0.5)
    
    local total = 0
    local serviceCounts = {}
    
    -- Count all instances in game
    for _, inst in ipairs(game:GetDescendants()) do
        total = total + 1
        if total % 1000 == 0 then
            statusLabel.Text = "Counting: " .. formatNumber(total) .. " instances so far..."
            task.wait()
        end
    end
    
    -- Count game itself
    total = total + 1
    
    -- Count per service
    for _, service in ipairs(game:GetChildren()) do
        local serviceTotal = 1 -- Count the service itself
        for _, inst in ipairs(service:GetDescendants()) do
            serviceTotal = serviceTotal + 1
        end
        serviceCounts[service.Name] = serviceTotal
    end
    
    -- Update total label
    totalLabel.Text = "Total: " .. formatNumber(total) .. " instances"
    statusLabel.Text = "Scan complete!"
    
    -- Sort services by count (largest first)
    local sortedServices = {}
    for name, count in pairs(serviceCounts) do
        table.insert(sortedServices, {name = name, count = count})
    end
    table.sort(sortedServices, function(a, b) return a.count > b.count end)
    
    -- Create service list labels
    for _, service in ipairs(sortedServices) do
        local serviceLabel = Instance.new("TextLabel")
        serviceLabel.Size = UDim2.new(1, 0, 0, 25)
        serviceLabel.BackgroundTransparency = 1
        serviceLabel.Text = service.name .. ": " .. formatNumber(service.count) .. " instances"
        serviceLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
        serviceLabel.TextSize = 12
        serviceLabel.TextXAlignment = Enum.TextXAlignment.Left
        serviceLabel.Parent = serviceList
        
        -- Color code based on size
        if service.count > 10000 then
            serviceLabel.TextColor3 = Color3.fromRGB(255, 150, 150)
        elseif service.count > 5000 then
            serviceLabel.TextColor3 = Color3.fromRGB(255, 200, 150)
        elseif service.count > 1000 then
            serviceLabel.TextColor3 = Color3.fromRGB(200, 255, 200)
        end
    end
    
    -- Update canvas size for scrolling
    serviceList.CanvasSize = UDim2.new(0, 0, 0, #sortedServices * 27)
    
    -- Print to console
    print("\n========== INSTANCE COUNT ==========")
    print("Total instances: " .. formatNumber(total))
    print("")
    print("Service breakdown:")
    for _, service in ipairs(sortedServices) do
        print("  " .. service.name .. ": " .. formatNumber(service.count))
    end
    print("====================================")
    
    return total
end

-- Start counting
coroutine.wrap(function()
    countInstances()
end)()
